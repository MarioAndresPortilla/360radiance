# ---------------------------------------------------------------------------
# 360 Radiance — environment variables
# ---------------------------------------------------------------------------
# All vars are set in Vercel → Project → Settings → Environment Variables.
# Anything you also need locally goes in .env.local (gitignored).
#
# The site is designed to run with NONE of these set — every integration
# falls back to a no-op or static snapshot — so feel free to deploy
# incrementally as Marta provisions accounts.
# ---------------------------------------------------------------------------


# ---- Resend (contact form, newsletter, Stripe order alerts) ----
# 1. Sign up at https://resend.com and create an API key
# 2. Verify a sender domain (e.g. mail.360radianceskincare.com) under Domains
# 3. Set these in Vercel
#
# Without these, contact form submissions and newsletter signups silently
# discard with a "service unavailable" error message in the UI.

# Server-only API key — never expose to the client.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered (inbox Marta actually checks).
CONTACT_EMAIL_TO=marta@360radianceskincare.com

# Verified sender — must use a domain you've verified in Resend, otherwise
# Resend rejects the send. Format: "Display Name <address@verified-domain>"
CONTACT_EMAIL_FROM=360 Radiance Website <noreply@mail.360radianceskincare.com>

# Optional — separate inbox for Stripe order notifications. Defaults to
# CONTACT_EMAIL_TO when unset.
ORDER_NOTIFICATION_EMAIL_TO=orders@360radianceskincare.com

# Optional — Resend audience ID for newsletter signups. When set, every
# newsletter form submission is auto-added to this audience as a backup
# persistence layer (in addition to the email notification to Marta).
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000


# ---- Stripe (DTC product checkout) ----
# 1. Sign up at https://stripe.com and grab the secret key from
#    Developers → API keys (use the LIVE key in Vercel production env,
#    the TEST key for preview / dev)
# 2. Create a webhook endpoint in Stripe → Developers → Webhooks pointing
#    at https://360radianceskincare.com/api/stripe-webhook with the
#    `checkout.session.completed` event subscribed
# 3. Copy the webhook signing secret into STRIPE_WEBHOOK_SECRET
#
# Cart UI is gated on whether STRIPE_SECRET_KEY is present (see
# src/lib/cart.tsx). Without it, every "Add to cart" button hides and the
# product modal falls back to "book a consult" — site stays fully usable.

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---- Sentry (error monitoring + session replay) ----
# 1. Sign up at https://sentry.io and create a Next.js project
# 2. Copy the DSN — set it as both SENTRY_DSN (server) AND
#    NEXT_PUBLIC_SENTRY_DSN (client). They're the same value; Next.js only
#    bundles `NEXT_PUBLIC_*` vars into the browser script.
# 3. SENTRY_ORG / SENTRY_PROJECT control source-map upload at build time.
#    Optional, but without them stack traces from production stay
#    minified — definitely set them once you have a project.
# 4. SENTRY_AUTH_TOKEN is needed for source-map uploads — generate one at
#    Settings → Auth Tokens with the `project:releases` scope. Set it
#    ONLY in Vercel (never commit).
#
# Sentry no-ops cleanly without any of these set — instrumentation files
# load, captureException becomes a no-op, build still passes.

SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXXX.ingest.sentry.io/XXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=360-radiance
SENTRY_PROJECT=360radiance-web
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---- Google reviews — live + snapshot pipeline ----
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable the "Places API (New)" — NOT the legacy Places API
# 3. Create an API key under "APIs & Services → Credentials"
# 4. Restrict the key:
#    - Application restriction: HTTP referrers → `*.360radianceskincare.com/*`
#      and `localhost:*` for local dev
#    - API restriction: Places API (New) only
# 5. Find the Place ID for 360 Radiance:
#    https://developers.google.com/maps/documentation/places/web-service/place-id
#    (paste the business name + address; the ID looks like `ChIJ...`)
# 6. Set both vars in Vercel → Project → Settings → Environment Variables
#    AND in .env.local for local builds + the manual sync script.
#
# When set, src/lib/google-reviews.ts fetches live reviews on every server
# render (cached 24h via Next's fetch revalidate). When unset, the site falls
# back to the snapshot in src/data/google-reviews.json (refresh that snapshot
# with `npm run sync:reviews`).
GOOGLE_PLACES_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxxxxxxxx
