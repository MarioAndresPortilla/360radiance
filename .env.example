# Contact form email delivery (Resend)
# 1. Sign up at https://resend.com and create an API key
# 2. Verify a sender domain (e.g. mail.360radianceskincare.com) under Domains
# 3. Set these in Vercel → Project → Settings → Environment Variables

# Server-only API key — never expose to the client.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered (inbox Marta actually checks)
CONTACT_EMAIL_TO=marta@360radianceskincare.com

# Verified sender — must use a domain you've verified in Resend, otherwise
# Resend rejects the send. Format: "Display Name <address@verified-domain>"
CONTACT_EMAIL_FROM=360 Radiance Website <noreply@mail.360radianceskincare.com>

# Google reviews — live + snapshot pipeline
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable the "Places API (New)" — NOT the legacy Places API
# 3. Create an API key under "APIs & Services → Credentials"
# 4. Restrict the key:
#    - Application restriction: HTTP referrers → `*.360radianceskincare.com/*`
#      and `localhost:*` for local dev
#    - API restriction: Places API (New) only
# 5. Find the Place ID for 360 Radiance:
#    https://developers.google.com/maps/documentation/places/web-service/place-id
#    (paste the business name + address; the ID looks like `ChIJ...`)
# 6. Set both vars in Vercel → Project → Settings → Environment Variables
#    AND in .env.local for local builds + the manual sync script.
#
# When set, src/lib/google-reviews.ts fetches live reviews on every server
# render (cached 24h via Next's fetch revalidate). When unset, the site falls
# back to the snapshot in src/data/google-reviews.json (refresh that snapshot
# with `npm run sync:reviews`).
GOOGLE_PLACES_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxxxxxxxx
